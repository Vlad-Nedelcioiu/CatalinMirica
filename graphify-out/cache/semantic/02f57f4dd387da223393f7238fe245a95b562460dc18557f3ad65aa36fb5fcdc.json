{"nodes": [{"id": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_home_page_critique", "label": "Home Page Design Critique (24/40)", "file_type": "document", "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Design Health Score / Overall Impression", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Dual-agent critique (design-review + detector-evidence) of app/page.tsx scoring 24/40: system primitives are real and obeyed, but the page assembles them into the generic 2024-26 template scroll, undermining the brand for the design-literate audience the studio sells to."}, {"id": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p1_mobile_hero_grid_holes", "label": "P1: Mobile Hero Grid Empty Holes", "file_type": "concept", "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hero.tsx:61 uses grid-cols-2 below lg with 1/2/1-span children in source order, leaving empty cells; matters because leads arrive warm from Instagram overwhelmingly on phones, so the first impression on the majority device looks broken."}, {"id": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p1_conversion_hierarchy_inversion", "label": "P1: Conversion Hierarchy Inverts Documented Strategy", "file_type": "concept", "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hero fills 'Book a session' and outlines the portfolio while PRODUCT.md's primary CTA is 'View portfolio'; four different labels (Book a Session, Book a session, See packages, Check availability) all route to /booking, breaking information scent with salesman-first ordering the brand rejects."}, {"id": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p1_wcag_contrast_failures", "label": "P1: WCAG AA Contrast Failures on Brass and Muted Text", "file_type": "concept", "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Brass #a9743f eyebrows measure 3.74:1 on cream and muted #8b857a 3.43:1 against a needed 4.5:1, on real content; fix is a text-safe brass step (#8a5a2b = 5.49:1), moving muted text to text-ink-soft, and darkening placeholders."}, {"id": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p1_reduced_motion_broken", "label": "P1: Reduced-Motion Promise Not Kept / Opacity-0 Gating", "file_type": "concept", "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The global CSS rule only neutralizes CSS animation; Framer Motion (every Reveal, testimonial crossfade, rAF counter) runs at full motion under prefers-reduced-motion, and initial opacity:0 server-renders below-fold content invisible for no-JS visitors; fix is MotionConfig reducedMotion='user' and a CSS-first default-visible reveal."}, {"id": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p2_template_scaffolding", "label": "P2: Template Scaffolding (Eyebrow Saturation, Stat Band, Icon-Card Grid)", "file_type": "concept", "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues / Anti-Patterns Verdict", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "7 of 8 sections carry the eyebrow (5 in an unsanctioned dash-less format), Stats.tsx is the banned hero-metric template running placeholder numbers, Services.tsx is the banned identical icon-card grid; strategically the biggest opportunity \u2014 cut scaffolding, move the work up, make Services photo-led."}], "edges": [{"source": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_home_page_critique", "target": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p1_mobile_hero_grid_holes", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues", "weight": 1.0}, {"source": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_home_page_critique", "target": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p1_conversion_hierarchy_inversion", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues", "weight": 1.0}, {"source": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_home_page_critique", "target": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p1_wcag_contrast_failures", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues", "weight": 1.0}, {"source": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_home_page_critique", "target": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p1_reduced_motion_broken", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_location": "Priority Issues", "weight": 1.0}, {"source": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_home_page_critique", "target": "_impeccable_critique_2026_07_14t09_32_03z__app_page_tsx_p2_template_scaffolding", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".impeccable/critique/2026-07-14T09-32-03Z__app-page-tsx.md", "source_locat