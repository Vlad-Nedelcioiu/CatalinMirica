# Copy to .env.local and adjust as needed.

# Optional: protect the /admin dashboard.
# If set, the admin page requires ?token=YOUR_VALUE (or an x-admin-token header on the API).
# Leave empty to keep /admin open for local development.
ADMIN_TOKEN=

# Email notifications via Resend (https://resend.com).
# Get a free API key at resend.com, then set the address you want to receive contact emails.
RESEND_API_KEY=
CONTACT_EMAIL=
